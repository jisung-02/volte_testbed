# ========================================
# volte-testbed Configuration
# ========================================

# ----------------------------------------
# PyHSS REST API (provision script 가 사용)
# ----------------------------------------
PYHSS_URL=http://localhost:8080

# ----------------------------------------
# srsENB Radio (enb-run 시 srslte_init.sh 가 enb.conf / rr.conf 에 주입)
# ----------------------------------------
# SRSENB_TX_GAIN — SDR 송신 출력 (dB). 단말이 받는 신호 세기.
#   범위: 0–89 (USRP B210 기준 안전 60–85)
#   60–70  : 차폐 환경 / 단말 가까움 / 외부 RF 약함
#   75–85  : 일반 환경 — 기본값 80
#   85–89  : 외부 셀 (LG U+/KT 등) 과 경쟁 강한 환경
#   ⚠ 너무 높이면 SDR 출력단 클리핑 → 스펙트럼 왜곡으로 디코딩 실패. RACH 안 잡히면 오히려 낮춰서 시도
SRSENB_TX_GAIN=80

# SRSENB_DL_EARFCN — 다운링크 주파수 채널 번호 (3GPP TS 36.101 Table 5.7.3-1)
#   1600 (Band 3, DL 1815 MHz) : 기본값. 한국 LG U+/KT 와 동일 대역 — 외부 셀 간섭 가능
#   1850 (Band 3, DL 1840 MHz) : 같은 Band 3 의 다른 채널 — 외부 셀 회피 시 시도
#   2452 (Band 5, DL  873 MHz) : 저대역 (벽 투과 ↑, 단말 호환성 ↓)
#   3100 (Band 7, DL 2655 MHz) : 고대역 (직진성 ↑, 거리 ↓)
#   ⚠ 변경 전 UE SIM/단말 spec 에서 해당 band 지원 여부 확인 필수. 미지원 band 면 cell search 자체 실패
#   ⚠ Band 변경 시 sib.conf 의 freqInfo 도 같이 검토 필요
SRSENB_DL_EARFCN=1600

